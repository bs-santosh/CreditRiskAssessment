# Distribution plots for key numerical features
key_features = ['age', 'credit_amount', 'duration']

fig, axes = plt.subplots(2, 3, figsize=(16, 10))
fig.suptitle('Distribution Analysis of Key Numerical Features', fontsize=16, fontweight='bold', y=1.00)

for idx, feature in enumerate(key_features):
    # Histogram
    axes[0, idx].hist(df[feature], bins=30, edgecolor='black', alpha=0.7, color='skyblue')
    axes[0, idx].set_title(f'{feature.replace("_", " ").title()} - Histogram', fontweight='bold')
    axes[0, idx].set_xlabel(feature.replace("_", " ").title())
    axes[0, idx].set_ylabel('Frequency')
    axes[0, idx].grid(axis='y', alpha=0.3)
    
    # Box plot
    axes[1, idx].boxplot(df[feature], vert=True, patch_artist=True,
                         boxprops=dict(facecolor='lightcoral', alpha=0.7),
                         medianprops=dict(color='darkred', linewidth=2))
    axes[1, idx].set_title(f'{feature.replace("_", " ").title()} - Box Plot', fontweight='bold')
    axes[1, idx].set_ylabel(feature.replace("_", " ").title())
    axes[1, idx].grid(axis='y', alpha=0.3)

plt.tight_layout()
plt.show()

# Statistical summary
print(f"\n{'='*60}")
print(f"DISTRIBUTION INSIGHTS")
print(f"{'='*60}")
for feature in key_features:
    print(f"\n{feature.upper()}:")
    print(f"  Mean: {df[feature].mean():.2f}")
    print(f"  Median: {df[feature].median():.2f}")
    print(f"  Std Dev: {df[feature].std():.2f}")
    print(f"  Skewness: {df[feature].skew():.3f}")
